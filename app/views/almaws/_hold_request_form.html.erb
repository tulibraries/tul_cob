<%= form_with url: hold_request_path, local: true, id: "hold-request-form", class: 'form-horizontal request-form', method: :post do |form| %>
  <div class="container" data-controller="request-form">

    <%= form.hidden_field :mms_id, value: params[:mms_id] %>
    <%= form.hidden_field :holding_id, value: @holding_id %>
    <%= form.hidden_field :item_pid, value: @item_pid %>
    <%= form.hidden_field :user_id, value: @user_id %>
    <%= form.hidden_field :request_level, value: @request_level %>

    <% if @equipment.empty?  && @request_level == "bib" %>
      <div class="row hold-form form-group">
        <%= label("", :hold_pickup_location, t("requests.form.pickup_locations_label")) %>
        <%= select_tag(:hold_pickup_location, request_select_options(@pickup_locations.collect { |lib| [ lib.values.first, lib.keys.first ] }, placeholder: ""), required: true, "aria-required": true, class: "request-form form-select") %>
      </div>
    <% end %>

    <% if @equipment.present? %>
      <div class="row hold-form form-group">
        <%= label("", :hold_pickup_location, t("requests.form.pickup_locations_label")) %>
        <%= select_tag(:hold_pickup_location, request_select_options(@equipment.collect { |lib| [ lib.fetch("desc", ""), lib.fetch("value", "") ] }.uniq, placeholder: ""), required: true, "aria-required": true, class: "request-form form-select") %>
      </div>
    <% end %>

    <% if @material_types.present? && @material_types.count > 1 %>
      <div class="row hold-form form-group">
        <%= label("", :material_type, t("requests.form.material_type_html")) %>
        <%= select_tag(:material_type, request_select_options(@material_types.collect { |mat| [ mat.values.last, mat.values.first ] }, placeholder: ""), class: "request-form form-select", data: { "action": "request-form#typeSelect" }) %>
      </div>
    <% else %>
      <%= form.hidden_field :material_type, value: @material_types.collect { |mat| [ mat.values.first ] } %>
    <% end %>

    <% if @request_level == "item" %>
      <% if @description.to_h.values.flatten.count > 1 %>
        <div class="row hold-form form-group">
          <%= form.label(:hold_description, t("requests.form.description_label_html")) %>
          <%= select_tag(:hold_description, request_grouped_select_options(@description, placeholder: "Select volume/issue or additional item details, if applicable"), { data: { "action": "request-form#select", "request-form-target": "descriptions" }, class: "request-form form-select", required: true, "aria-required": true } ) %>
        </div>
      <% else %>
        <%= form.hidden_field :hold_description, value: @description.flatten.last %>
      <% end %>

      <div class="row hold-form form-group">
        <%= label("", :hold_pickup_location, t("requests.form.pickup_locations_label")) %>
        <%= select_tag(:hold_pickup_location, request_grouped_select_options(@item_level_locations, placeholder: ""), { data: { "request-form-target": "pickups" },  class: "request-form form-select", required: true, "aria-required": true }) %>
      </div>
    <% end %>

    <div class="row hold-form">
      <%= form.submit t("requests.form.submit"), class:"btn btn-primary", data: { disable_with: "Sending request..." } %>
    </div>
  </div>
<% end %>
