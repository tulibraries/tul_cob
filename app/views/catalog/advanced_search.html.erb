<% @page_title = t("blacklight.advanced_search.page_title", application_name: application_name) %>

<% content_for :skip_links do %>
  <a class="visually-hidden-focusable" href="#advanced-search-form">Skip to advanced search form</a>
<% end %>

<div class="advanced-search-form col-sm-12">
  <div class="row">
    <div class="col-xl-9" id="advanced-search-form">
      <%= render "advanced_search_form" %>
    </div>

    <div class="col-xl-3 mt-xl-0 mt-4">
      <%= render "advanced_search_help" %>
    </div>
  </div>
</div>
