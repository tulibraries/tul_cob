<div>
  <% document.citations.each do |format, citation| %>
    <% unless format == "NULL" %>
      <div class="citation-format-group" data-controller="citation-copy">
        <% label = citation_labels(format) %>
        <% copy_action = "click->citation-copy#copy" %>
        <h3 class="citation-heading citation-format">
          <%= label %>
          <button
            type="button"
            class="citation-copy-btn"
            data-action="<%= copy_action %>"
            aria-label="Copy citation for <%= label %>"
          >
            <%= image_tag("svg/copy.svg", alt: "", "aria-hidden": true) %>
          </button>
        </h3>
        <div class="citation-copy-content" data-citation-copy-target="content">
          <%= citation %>
        </div>
      </div>
    <% end %>
    <% if format == "NULL" %>
      <%= citation %>
    <% end %>
  <% end %>
</div>
