default: &default
  alma:
    apikey: "EX_LIBRIS_DEVELOPERS_NETWORK_APIKEY"
    institution_code: "01TULI_INST"
    delivery_domain: "sandbox01-na.alma.exlibrisgroup.com"
    auth_secret: "SUUUPER SECRET KEYYYYY"
    timeout: 10
  bento:
    primo:
      api_base_url: "api-na.hosted.exlibrisgroup.com"
      apikey: "YOUR_LONG_API_KEY"
      scope: "pci_scope"
      vid: "TULI"
      web_ui_base_url: "https://your-primo.hosted.exlibrisgroup.com/primo-explore/fulldisplay?docid="
    libkey:
      apikey: "LIBKEY_API_KEY"
      base_url: "https://public-api.thirdiron.com/public/v1/libraries"
      library_id: "130"
  email_groups:
    RAPID_REQUEST:
      - "<EMAIL_ADDRESS>"
  lib_guides:
    base_url: "https://lgapi-us.libapps.com/1.1/guides"
    api_key: "LIB_GUIDES_API_KEY"
    site_id: 17
    query:
      sort_by: "relevance"
      expand: "owner"
      guide_types: "1,2,3,4"
      status: 1
  archives_space:
    public_base_url: "https://scrcarchivesspace.temple.edu"
    staff_api_base_url: "https://scrcarchivesspace.temple.edu/staff/api"
    username: "test-user"
    password: "test-pass"
    open_timeout: 2
    timeout: 5
  quik_pay:
    secret: "MyQuikPaySecret"
    redirect_url: "http://localhost:3000/users/quik_pay_callback"
    url: "https://uatquikpayasp.com/temple2/library/guest.do?"
  microsoft_graph_mailer:
    tenant_id: "<GRAPH_TENANT_ID>"
    client_id: "<GRAPH_CLIENT_ID>"
    client_secret: "<GRAPH_CLIENT_SECRET>"
  oclc:
    apikey: "ws_key"
    base_url: "https://www.worldcat.org/webservices/catalog/content/citations"
    citation_formats: ["all"]
  honeybadger:
    api_key: "foobar"
    token: "honeybadger-token"
    exceptions:
      ignore:
        - "Alma::BibRequest::ItemAlreadyExists"
development:
  <<: *default

test:
  <<: *default
  honeybadger:
    backend: "test"

production:
  <<: *default
