default: &default
  alma:
    apikey: "EX_LIBRIS_DEVELOPERS_NETWORK_APIKEY"
    institution_code: "01TULI_INST"
    delivery_domain: "sandbox01-na.alma.exlibrisgroup.com"
    auth_secret: "SUUUPER SECRET KEYYYYY"
    timeout: 10
  bento:
    primo:
      api_base_url: "api-na.hosted.exlibrisgroup.com"
      apikey: "YOUR_LONG_API_KEY"
      scope: "pci_scope"
      vid: "TULI"
      web_ui_base_url: "https://your-primo.hosted.exlibrisgroup.com/primo-explore/fulldisplay?docid="
    libkey:
      apikey: "LIBKEY_API_KEY"
      base_url: "https://public-api.thirdiron.com/public/v1/libraries"
      library_id: "130"
  cdm:
    base_url: "https://digital.library.temple.edu"
    collection_ids:
      - p15037coll1
      - p15037coll2
      - p15037coll3
      - p15037coll4
      - p15037coll5
      - p15037coll7
      - p15037coll10
      - p15037coll14
      - p15037coll15
      - p15037coll17
      - p15037coll18
      - p15037coll19
      - p16002coll1
      - p16002coll2
      - p16002coll3
      - p16002coll4
      - p16002coll5
      - p16002coll6
      - p16002coll7
      - p16002coll9
      - p16002coll10
      - p16002coll11
      - p16002coll12
      - p16002coll14
      - p16002coll16
      - p16002coll17
      - p16002coll18
      - p16002coll19
      - p16002coll20
      - p16002coll21
      - p16002coll22
      - p16002coll23
